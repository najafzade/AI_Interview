
{
  "entities": {
    "InterviewSession": {
      "title": "Interview Session",
      "description": "A complete record of an interview, including multi-modal history and per-turn metadata for model evaluation.",
      "type": "object",
      "properties": {
        "candidateName": { "type": "string" },
        "skill": { "type": "string" },
        "status": { "type": "string", "enum": ["IN_PROGRESS", "COMPLETED"] },
        "promptVersion": { "type": "string", "description": "The specific version of instructions used by the agent." },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "speaker": { "type": "string", "enum": ["ai", "candidate"] },
              "text": { "type": "string", "description": "The transcribed text or model response." },
              "audioDataUri": { "type": "string", "description": "The raw audio source for this turn." },
              "evaluations": {
                "type": "object",
                "properties": {
                  "asrRating": { "type": "number", "description": "1-5 rating of transcription accuracy." },
                  "ttsRating": { "type": "number", "description": "1-5 rating of voice quality." },
                  "logicRating": { "type": "number", "description": "1-5 rating of model reasoning." },
                  "flags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["candidateName", "skill", "status", "promptVersion", "createdAt"]
    },
    "PromptConfig": {
      "title": "Prompt Configuration",
      "description": "Versioned system instructions for the interview agent.",
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "isActive": { "type": "boolean" },
        "instructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["version", "isActive", "instructions", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/InterviewSession" },
      "description": "Collection of all interview sessions with embedded turn-level evaluation data."
    },
    "/prompt_configs/{configId}": {
      "schema": { "$ref": "#/backend/entities/PromptConfig" },
      "description": "Versioned system prompts"
    }
  }
}
